rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /portfolio/{allPaths=**} {
      // Public can view portfolio media
      allow read: if true;
      // Only Admin can upload/delete
      allow write: if request.auth != null && 
                   (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.token.email == 'hi@arrdublu.us');
    }
  }
}
